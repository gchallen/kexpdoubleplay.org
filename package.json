{
  "name": "kexp-doubleplay",
  "version": "2026.3.0",
  "description": "KEXP Double Play Scanner - Cloudflare Worker",
  "private": true,
  "workspaces": [
    "types",
    "worker"
  ],
  "scripts": {
    "dev": "cd worker && wrangler dev",
    "deploy": "cd worker && bun run deploy",
    "build": "bun --filter=types build",
    "test": "bun --filter=worker test",
    "check": "cd types && bun run build && cd ../worker && npx tsc --noEmit -p tsconfig.json",
    "ncu": "bunx npm-check-updates --deep",
    "tail": "cd worker && wrangler tail",
    "sync-db": "bash scripts/sync-db.sh"
  },
  "keywords": ["kexp", "radio", "double-play", "scanner"],
  "author": "",
  "license": "ISC"
}
